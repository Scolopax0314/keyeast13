# Unity .gitignore Template
# Based on official GitHub Unity template:
#   https://github.com/github/gitignore/blob/main/Unity.gitignore
# Generated and modified with reference to:
#   https://www.toptal.com/developers/gitignore
# Custom-tailored for VSCode-based Unity projects.

# Unity 디렉터리 및 캐시 무시
[Ll]ibrary/
[Tt]emp/
[Oo]bj/
[Bb]uild/
[Bb]uilds/
[Ll]ogs/
[Uu]ser[Ss]ettings/
MemoryCaptures/
.crashlytics/

# Unity Collaborate 및 Version Control 무시
.collabignore
.plastic/
.PlasticSCM/

# 빌드 결과물 무시 (Android, iOS, Desktop 등)
*.apk
*.aab
*.unitypackage
*.app
*.xcworkspace
*.xcuserdata/
*.xcodeproj/project.xcworkspace/
*.xcodeproj/xcuserdata/

# Unity Addressables 빌드 산출물 무시
[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/
[Aa]ssets/[Ss]treamingAssets/aa.meta
[Aa]ssets/[Ss]treamingAssets/aa/

# OS 별 무시 항목
.DS_Store
Thumbs.db
desktop.ini

# IDE 및 자동 생성 파일 (VSCode 중심 구성)
.vscode/
*.csproj
*.sln
*.unityproj
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# Git에 반드시 포함시켜야 하는 Unity 메타 및 설정 파일
!Assets/**/*.meta
!ProjectSettings/**/*.asset
!Packages/**/*.json